{
  "name": "obsidian-sample-plugin",
  "version": "1.0.0",
  "description": "This is a sample plugin for Obsidian (https://obsidian.md)",
  "main": "main.js",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build:styles": "bun run build-styles.mjs",
    "watch:styles": "bun run build-styles-watch.mjs",
    "dev": "bun run build:styles && bun run dev.mjs",
    "build": "bun run build:styles && tsc --noEmit --skipLibCheck && bun run esbuild.config.mjs production",
    "version": "bun run version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@eslint/js": "9.30.1",
    "@types/express": "^5.0.6",
    "@types/node": "^16.11.6",
    "@types/ws": "^8.18.1",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1"
  },
  "dependencies": {
    "express": "^5.2.1",
    "obsidian": "latest",
    "preact": "^10.29.0",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0"
  }
}
